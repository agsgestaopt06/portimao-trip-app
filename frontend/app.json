{
  "expo": {
    "name": "Portimão '26",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.benagilbudgettrip.bwmq94",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Guardar fotos da vossa viagem a Portimão",
        "NSCameraUsageDescription": "Tirar fotos das memórias da viagem"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1D8086"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.benagilbudgettrip.bwmq94",
      "permissions": ["READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1D8086"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Guardar fotos da vossa viagem a Portimão."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
